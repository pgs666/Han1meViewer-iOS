    "匹配包含任一已选标签的影片。关闭时更接近精确组合。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Match videos containing any selected tag. Turn off for a stricter combination."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "匹配包含任一已选标签的影片。关闭时更接近精确组合。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "比對包含任一已選標籤的影片。關閉時更接近精確組合。"
          }
        }
      }
    },
